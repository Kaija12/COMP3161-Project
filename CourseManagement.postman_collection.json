              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/courses/{{course_id}}/assignments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Assignment 1\",\n  \"description\": \"Implement a linked list.\",\n  \"due_date\": \"2025-04-01 23:59:00\",\n  \"max_grade\": 100\n}"
            }
          }
